                {
                    "name": "Export Credentials",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/terminal-credentials/export?mask_terminal_key=true",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "terminal-credentials",
                                "export"
                            ],
                            "query": [
                                {
                                    "key": "mask_terminal_key",
                                    "value": "true",
                                    "description": "true to mask keys, false to export actual keys"
