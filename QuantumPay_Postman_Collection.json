{
    "info": {
        "name": "QuantumPay VNP Integration",
        "description": "API endpoints to manage Terminal Credentials, Charge Files, and Processing. All endpoints use Bearer Token authentication. Add your JWT token to the collection variables ({{jwt_token}}).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3001/api",
            "type": "default"
        },
        {
            "key": "jwt_token",
            "value": "PASTE_YOUR_JWT_TOKEN_HERE",
            "type": "default",
            "description": "JWT Bearer token from login endpoint"
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{jwt_token}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "Authentication",
            "description": "Authentication endpoints for user registration, login, and OTP verification. All endpoints use Bearer Token authentication except login/register.",
            "auth": {
                "type": "noauth"
            },
            "item": [
                {
                    "name": "Register (Sign Up)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "description": "Register a new user account. Returns JWT token immediately (no OTP for registration)."
                    }
                },
                {
                    "name": "Login (Step 1 - Send OTP)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secure_password_123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Login with email/password. Sends 6-digit OTP to email. Copy sessionToken from response for Step 2."
                    }
                },
                {
                    "name": "Verify OTP (Step 2 - Complete Login)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"sessionToken\": \"PASTE_SESSION_TOKEN_FROM_LOGIN_RESPONSE\",\n  \"otp\": \"123456\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/verify-otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "verify-otp"
                            ]
                        },
                        "description": "Verify the 6-digit OTP from email. Returns JWT token. Copy token to {{jwt_token}} collection variable."
                    }
                },
                {
                    "name": "Resend OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"sessionToken\": \"PASTE_SESSION_TOKEN_FROM_LOGIN_RESPONSE\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/resend-otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "resend-otp"
                            ]
                        },
                        "description": "Resend OTP if the previous one expired. Use the same sessionToken from login response."
                    }
                },
                {
                    "name": "Get Profile",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/auth/profile",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "profile"
                            ]
                        },
                        "description": "Get current user profile information. Requires Bearer token."
                    },
                    "auth": {
                        "type": "bearer",
                        "bearer": [
                            {
                                "key": "token",
                                "value": "{{jwt_token}}",
                                "type": "string"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Terminal Credentials Vault",
            "description": "Manage QuantumPay terminal credentials per hotel",
            "auth": {
                "type": "bearer",
                "bearer": [
                    {
                        "key": "token",
                        "value": "{{jwt_token}}",
                        "type": "string"
                    }
                ]
            },
            "item": [
                {
                    "name": "Create Credential",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"hotel_id\": \"EXPEDIA_HOTEL_ID_123\",\n  \"username\": \"terminal_user\",\n  \"terminal_key\": \"your_terminal_key_12345\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/terminal-credentials",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "terminal-credentials"
                            ]
                        }
                    }
                },
                {
                    "name": "List Credentials",
                    "request": {
                        "method": "GET",
                        "header": [],
