                                {
                                    "key": "id",
                                    "value": "CREDENTIAL_ID",
                                    "description": "Credential ObjectId"
                                }
                            ],
                            "query": [
                                {
                                    "key": "include_key",
                                    "value": "false",
                                    "disabled": true,
                                    "description": "true to include decrypted terminal_key in response"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Update Credential",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"new_username\",\n  \"terminal_key\": \"new_terminal_key\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/terminal-credentials/:id",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "terminal-credentials",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "CREDENTIAL_ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Credential",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/terminal-credentials/:id",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "terminal-credentials",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "CREDENTIAL_ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Bulk Import Credentials",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": ""
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/terminal-credentials/import",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "terminal-credentials",
                                "import"
                            ]
                        },
                        "description": "Upload XLSX/CSV file with columns: hotel_id, username, terminal_key"
                    }
